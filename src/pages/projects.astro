const sortedProjects = [...projects].sort((a, b) => Number(b.year) - Number(a.year));
---

<script>
  import { timeline, type TimelineDefinition } from "motion";
  import { loaderAnimation } from "../lib/constants";

  timeline([loaderAnimation] as TimelineDefinition);
</script>

<Layout title="Gerind Tershana - Projects" description="A collection of some of my projects">
  <main class="flex flex-col justify-center items-center just p-4 pt-40">
    <a href="/" aria-label="Back to homepage" class="fixed top-10 left-10 text-white bg-neutral-900 hover:bg-neutral-800 w-fit px-4 py-2 border-1 border-solid border-neutral-600 rounded-lg">Back</a>
    <h1 class="text-white text-3xl md:text-4xl font-bold mb-4">Projects</h1>
    <p class="text-white mb-10">Here are some of the projects I have built throughout the years.</p>

    <section aria-label="Project list" class="w-fit grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        sortedProjects.map((project) => (
          <article class="group perspective">
            <div class="flex justify-between items-center text-gray-300 mb-2 gap-2">
              <div class="flex items-center gap-2 min-w-0">
                <span class="truncate">{project.title}</span>
              </div>
              <span class="text-sm text-gray-400">{project.year}</span>
            </div>
            <div class="relative transform transition-all duration-300 group-hover:rotate-y-12 group-hover:scale-105 group-hover:shadow-xl">
              {project.embedAsIframe ? (
                <iframe src={project.site} title={project.title} loading="lazy" referrerpolicy="strict-origin-when-cross-origin" class="w-80 h-90 rounded-md border border-neutral-700 bg-neutral-900" />
              ) : (
                <img src={project.img} class={`w-80 h-90 rounded-md ${project.class}`} alt={project.alt} loading="lazy" decoding="async" width="320" height="360" />
              )}
              <div class="absolute top-2 left-2 z-10 flex flex-wrap gap-1 max-w-[70%]">
                {project.statuses.map((status) => (
                  <span class={`text-[11px] px-2 py-0.5 rounded-full whitespace-nowrap backdrop-blur-sm ${statusClasses[status]}`}>{statusLabels[status]}</span>
                ))}
              </div>
              <div class="absolute top-2 right-2 z-10 flex gap-1.5 rounded-md border border-white/20 bg-black/40 p-1.5 backdrop-blur-sm">
                {project.stacks.map((stack) => (
                  <span title={techIcons[stack].label} aria-label={techIcons[stack].label}>
                    <Icon name={techIcons[stack].icon} class="h-4 w-4" />
                  </span>
                ))}
              </div>
              <div class="absolute inset-0 bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 transition-opacity rounded-lg flex flex-col items-center justify-center p-4">
                {project.site !== "#" && (
                  <a
                    href={project.site}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full max-w-56 mb-3 text-white bg-black/70 border border-white/70 hover:bg-black hover:border-blue-300 hover:text-blue-100 font-semibold rounded-md px-3 py-2 flex items-center justify-center transition-colors"
                  >
                    <Icon name="bx:link" class="h-5 w-5 mr-1.5" />
                    Check it out
                  </a>
                )}
                {project.github !== "#" && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full max-w-56 text-white bg-black/70 border border-white/70 hover:bg-black hover:border-blue-300 hover:text-blue-100 font-semibold rounded-md px-3 py-2 flex items-center justify-center transition-colors"
                  >
                    <Icon name="ri:github-fill" class="h-5 w-5 mr-1.5" />
                    Check it out on Github
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>
</Layout>

<style>
  .perspective {
    perspective: 1000px;
  }
  .rotate-y-12 {
    transform: rotateY(12deg);
  }
</style>
