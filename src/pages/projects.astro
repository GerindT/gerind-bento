---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const statusClasses = {
  live: "bg-green-500/20 text-green-200 border border-green-400/40",
  concept: "bg-violet-500/20 text-violet-200 border border-violet-400/40",
  dev_only: "bg-amber-500/20 text-amber-200 border border-amber-400/40",
  private: "bg-slate-500/25 text-slate-200 border border-slate-400/40",
} as const;

const statusLabels = {
  live: "Live",
  concept: "Concept",
  dev_only: "Dev only",
  private: "Private",
} as const;

type ProjectStatus = keyof typeof statusClasses;

const techIcons = {
  vue: { label: "Vue", icon: "logos:vue" },
  react: { label: "React", icon: "logos:react" },
  nuxt: { label: "Nuxt", icon: "logos:nuxt-icon" },
  golang: { label: "Golang", icon: "logos:go" },
  laravel: { label: "Laravel", icon: "logos:laravel" },
  php: { label: "PHP", icon: "logos:php" },
  nodejs: { label: "Node.js", icon: "logos:nodejs-icon" },
  mysql: { label: "MySQL", icon: "logos:mysql" },
  mongodb: { label: "MongoDB", icon: "logos:mongodb-icon" },
  postgresql: { label: "PostgreSQL", icon: "logos:postgresql" },
  supabase: { label: "Supabase", icon: "logos:supabase-icon" },
  redis: { label: "Redis", icon: "logos:redis" },
  python: { label: "Python", icon: "logos:python" },
  vectordb: { label: "Vector DB", icon: "ri:database-2-line" },
  k8s: { label: "K8s", icon: "logos:kubernetes" },
} as const;

type TechStack = keyof typeof techIcons;

type Project = {
  img: string;
  alt: string;
  github: string;
  site: string;
  embedAsIframe?: boolean;
  class: string;
  title: string;
  year: string;
  statuses: ProjectStatus[];
  stacks: TechStack[];
};

